# Copy to agent-service/.env and adjust. .env is git-ignored.

# Hugging Face cache. Point at a SHARED cache to avoid re-downloading the ~8GB model
# (e.g. reuse an existing shared/home-level Hugging Face cache). Must be set
# BEFORE transformers is imported — the app loads this .env first, so that's handled.
HF_HOME=./.hf_cache

# Model (Gemma 4 E4B, instruction-tuned).
MODEL_ID=google/gemma-4-E4B-it

# Optional: only helps with HF download rate limits (model is not gated).
# HF_TOKEN=hf_xxx

# Generation defaults.
MAX_NEW_TOKENS=2048
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.95

# Bearer API key for the web API (agent.api). If set, /v1 endpoints require
#   Authorization: Bearer <key>. If empty, auth is DISABLED (dev only; logs a warning).
# Generate one with:
#   python -c "import secrets; print('agt_' + secrets.token_urlsafe(32))"
GOTOAI_AGENT_API_KEY=

# Web-API server (agent.api). Bind to 0.0.0.0 only behind a proxy / when you mean to expose it.
API_HOST=127.0.0.1
API_PORT=8000
# Load the model at startup so the first request is fast and /readyz is meaningful.
# Set to 0 to defer loading until the first request.
API_EAGER_LOAD=1

# Google Geocoding API key (geocode task: event venue/location -> coordinates).
GOOGLE_GEOCODING_API_KEY=
# Result biasing (defaults suit Japanese events) and the local billing cache path.
GEOCODE_LANGUAGE=ja
GEOCODE_REGION=jp
# GEOCODE_CACHE=./.cache/geocode_cache.json
