# Copy to web-app/.env and adjust. .env is git-ignored.

# Where the pipeline's DATA/ tree lives. Default resolves to ../DATA relative to
# the web-app/ directory (i.e. the repo's DATA/). Override for other layouts.
# DATA_DIR=../DATA

# agent-service (the Gemma model host) base URL. The web-app proxies chat here.
AGENT_SERVICE_URL=http://127.0.0.1:8000

# Bearer key expected by agent-service's /v1 endpoints. Must match agent-service's
# GOTOAI_AGENT_API_KEY. Leave empty only if agent-service has auth disabled (dev).
GOTOAI_AGENT_API_KEY=

# This web-app's own HTTP server. WEB_HOST=0.0.0.0 exposes it to the LAN (reachable at
# http://<this-host-LAN-IP>:<WEB_PORT>); use 127.0.0.1 to restrict to localhost.
WEB_HOST=0.0.0.0
WEB_PORT=8080

# UI + chat language (matches the data and present-messages default).
UI_LANGUAGE=ja
